# =================================================
# Smart Exam Hall Entry Verification System
# Backend Environment Variables
# =================================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-hall-entry

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# AES-256 Encryption (must be 32 bytes hex for key, 16 bytes hex for IV)
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AES_IV=0123456789abcdef0123456789abcdef

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Client URLs (for CORS and email links)
CLIENT_URL=http://localhost:5173
STUDENT_CLIENT_URL=http://localhost:5174

# Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30

# QR Code
QR_EXPIRY_HOURS=24
